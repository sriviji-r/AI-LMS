# Database (Use local MongoDB or your MongoDB Atlas connection string)
MONGODB_URL=mongodb://127.0.0.1:27017/ai_lms

# Authentication
JWT_SECRET=super_secret_jwt_key_for_lms_12345

# Cloudinary (For uploading images/videos. Sign up free at cloudinary.com)
# If you don't have this, the server might crash on startup because it tries to connect on load.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ... your other variables ...

# Razorpay (Dummy keys just to prevent the server from crashing)
RAZORPAY_KEY_ID=rzp_test_dummy_123456789
RAZORPAY_SECRET=dummy_secret_key_123456789
# Email (Use a Gmail address and generate an "App Password" in your Google Account settings)
MAIL_HOST=smtp.gmail.com
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password

# AI Features (Get a free API key from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# Misc
FOLDER_NAME=ai_lms
PORT=4000